{
  "env":     { "node": true, "mocha": true, "es2022": true },
  "extends": ["eslint:recommended"],
  "parserOptions": { "ecmaVersion": 2022 },
  "rules": {
    "no-unused-vars": "warn",
    "no-console":     "off",
    "semi":           ["error", "always"],
    "quotes":         ["error", "double"],
    "eqeqeq":         "error",
    "no-var":         "error",
    "prefer-const":   "warn"
  }
}
